@page "/lunch"
@page "/LunchMenu"
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Lunch Menu for @MenuDate</h3>

@if (!string.IsNullOrEmpty(EventMessage))
{
    <p><strong>Event:</strong> @EventMessage</p>
}

<ul>
    @foreach (var item in TodayMenu)
    {
        <li>@item</li>
    }
</ul>

@code {
    private string MenuDate = "";
    private List<string> TodayMenu = new();
    private string? EventMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var response = await Http.GetFromJsonAsync<JsonElement>($"{baseUri}/api/lunch");

            if (response.TryGetProperty("date", out var dateProp))
            {
                if (DateTime.TryParse(dateProp.GetString(), out var parsed))
                    MenuDate = parsed.ToString("MMMM dd, yyyy");
                else
                    MenuDate = dateProp.GetString() ?? "";
            }

            if (response.TryGetProperty("menu", out var menuProp) && menuProp.ValueKind == JsonValueKind.Array)
            {
                TodayMenu = menuProp.EnumerateArray()
                    .Select(m => m.GetString() ?? "")
                    .Where(s => !string.IsNullOrEmpty(s))
                    .ToList();
            }

            if (response.TryGetProperty("eventMessage", out var eventProp) && eventProp.ValueKind == JsonValueKind.String)
            {
                EventMessage = eventProp.GetString();
            }
        }
        catch (Exception ex)
        {
            TodayMenu = new() { $"Error loading menu: {ex.Message}" };
        }
    }
}
